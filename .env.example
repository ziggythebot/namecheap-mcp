NAMECHEAP_API_USER=your_username
NAMECHEAP_API_KEY=your_api_key
NAMECHEAP_USERNAME=your_username
NAMECHEAP_CLIENT_IP=your_ip_address
NAMECHEAP_SANDBOX=false

# Affiliate tracking (from Impact dashboard)
# Campaign ID from tracking link: utm_campaign=7069952
NAMECHEAP_AFFILIATE_ID=7069952
NAMECHEAP_AFFILIATE_NETWORK=ir

# Optional: Use Batchit hosted API (zero setup)
# If set, MCP will use this instead of direct Namecheap API
# BATCHIT_API_URL=https://your-batchit-api.railway.app
